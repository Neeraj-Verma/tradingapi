# Streamlit Secrets Configuration
# Copy this to .streamlit/secrets.toml and fill in values

# ==================== Authentication ====================
# Users who can access the app (username = password hash or simple password)
[auth]
enabled = true
session_timeout_minutes = 480  # 8 hours

# Simple password authentication (for personal use)
# In production, use OAuth or more secure methods
[auth.users]
admin = "admin123"           # Change this!
neeraj = "trading2026"       # Change this!

# ==================== Kite API ====================
[kite]
api_key = "your_api_key"
api_secret = "your_api_secret"
# access_token is generated daily, stored in session

# ==================== Cloud API ====================
[cloud_api]
url = "https://gemini-adk-agents-vpunjpdcba-uc.a.run.app"
key = "kite-agents-2026-secure-key"
timeout = 60

# ==================== Risk Settings ====================
[risk]
max_sector_exposure = 0.30
max_drawdown_limit = 0.10
max_stocks_per_sector = 3

# ==================== Budget ====================
[budget]
daily = 100000
per_stock = 10000
max_qty = 500
