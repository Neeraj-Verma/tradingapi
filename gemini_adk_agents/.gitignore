# Gemini ADK Agents - Git Ignore

# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Data (keep structure but ignore content)
data/output/*
data/cache/*
!data/output/.gitkeep
!data/cache/.gitkeep

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Google Cloud
.gcloud/
service-account*.json
